#include <iostream>
#include <string>
#include <vector>

using namespace std;

// Function to check if a given length 'l' can turn off all bulbs in <= k operations
bool canTurnOff(int n, int k, int l, const string& bulbs) {
    int operations = 0;
    int i = 0;
    
    while (i < n) {
        // If the current bulb is ON, we must use an operation starting here
        if (bulbs[i] == '1') {
            operations++;
            // This operation covers bulbs from index i to i + l - 1
            i += l; 
        } else {
            // If the bulb is already OFF, move to the next one
            i++;
        }
        
        // If operations exceed k, this 'l' is too small
        if (operations > k) return false;
    }
    
    return operations <= k;
}

int main() {
    int n, k;
    if (!(cin >> n >> k)) return 0;
    
    string bulbs;
    cin >> bulbs;

    // Binary search for the smallest l in range [1, n]
    int low = 1, high = n;
    int ans = n;

    while (low <= high) {
        int mid = low + (high - low) / 2;
        
        if (canTurnOff(n, k, mid, bulbs)) {
            ans = mid;      // Current mid works, try to find a smaller value
            high = mid - 1;
        } else {
            low = mid + 1;  // Current mid is too small, increase l
        }
    }

    cout << ans << endl;

    return 0;
}
